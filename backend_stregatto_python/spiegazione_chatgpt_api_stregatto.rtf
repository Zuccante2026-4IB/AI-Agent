@app.post("/plugins/upload")\
async def upload_plugin(file: UploadFile):\
    path = f"/plugins/\{file.filename\}"\
    \
    with open(path, "wb") as f:\
        f.write(await file.read())\
\
    # reload Cheshire Cat\
    requests.post(f"\{CAT_URL\}/v1/plugins/reload")\
\
    return \{"status": "installed"\}\
\
