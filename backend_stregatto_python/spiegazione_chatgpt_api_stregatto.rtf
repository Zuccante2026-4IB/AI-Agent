\f2\b0\fs26 \cf0 \
from fastapi import FastAPI\
import requests\
\
app = FastAPI()\
\
CAT_URL = "http://cheshire-cat:1865"\
\
@app.post("/chat")\
async def chat(user_id: str, message: str):\
    response = requests.post(\
        f"\{CAT_URL\}/v1/chat",\
        json=\{\
            "text": message,\
            "conversation_id": user_id\
        \}\
    )\
\
    data = response.json()\
\
    return \{\
        "reply": data.get("content"),\
        "raw": data\
    \}\
\
